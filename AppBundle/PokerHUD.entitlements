<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox is required for Mac App Store distribution. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Outbound HTTPS for Supabase auth, Supabase REST, StoreKit 2
         receipt verification, and App Store sandbox product lookups. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- The user picks the PokerStars hand history directory via NSOpenPanel;
         the sandbox grants read-only access to exactly that folder and its
         descendants. -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>

    <!-- Security-scoped bookmarks let the folder choice survive across app
         relaunches (otherwise the user would have to re-pick on every launch).
         AppState persists the bookmark as Data in UserDefaults and calls
         startAccessingSecurityScopedResource() before starting the file
         watcher. -->
    <key>com.apple.security.files.bookmarks.app-scope</key>
    <true/>
</dict>
</plist>
