# macOS Finder metadata
.DS_Store

# Swift Package Manager build output
.build/
Package.resolved.local

# Xcode per-user state — keep xcshareddata/ tracked so shared schemes
# survive for every developer, but exclude xcuserdata/ which holds the
# individual developer's window layout, breakpoints, and scheme picker.
xcuserdata/
*.xcuserstate

# Xcode derived data + build caches
DerivedData/
build/

# Xcode automatic backups
*~.nib
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Fastlane + Crashlytics artefacts (we don't use these today, included
# for completeness so future integrations don't pollute the tree)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Objective-C / Playground leftovers (paranoia — not expected)
*.playground
timeline.xctimeline
playground.xcworkspace
